# DDSM Configuration

# Public IP address of your server (shown in connect strings)
DDSM_SERVER_IP=0.0.0.0

# RCON password used to query server status (must match start.sh)
DDSM_RCON_PASSWORD=ddsm_rcon_secret

# Directory where server instance data is stored
DDSM_SERVERS_DIR=/opt/deadlock-servers

# Docker image name for the Deadlock server
DDSM_DOCKER_IMAGE=deadlock-server
